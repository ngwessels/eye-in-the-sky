# Copy to .env.local (never commit .env*)

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/eyeinthesky?retryWrites=true&w=majority

# AWS S3 (server-side presigning only; Pi uses presigned URLs)
AWS_REGION=us-east-1
# If the bucket is not in AWS_REGION, set this so presigned PUT URLs do not 301-redirect (breaks Node fetch).
# S3_BUCKET_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=eye-in-the-sky-captures

# Admin bootstrap (register new stations)
ADMIN_SECRET=change-me-long-random

# Apple Weather Kit (optional; leave empty to skip weather orchestration)
APPLE_TEAM_ID=
APPLE_SERVICE_ID=
APPLE_KEY_ID=
# Local: path to AuthKey_*.p8. Vercel/production: set APPLE_PRIVATE_KEY in the dashboard instead (full PEM, Secret).
# APPLE_PRIVATE_KEY=
APPLE_PRIVATE_KEY_PATH=

# Vercel AI Gateway (https://vercel.com/docs/ai-gateway)
AI_GATEWAY_API_KEY=

# Default vision model (provider/model)
AI_VISION_MODEL=openai/gpt-4o

# Orchestrator / closed-loop (cron secret for Vercel Cron or manual curl)
CRON_SECRET=change-me-cron

# Clock skew: reject finalize vs accept with clock_untrusted + tier penalty
# CLOCK_SKEW_MODE=reject
# CLOCK_SKEW_MODE=downrank
# MAX_CAPTURE_BYTES=41943040

# Rate limits (optional overrides)
# RATE_POLL_PER_MIN=30
# RATE_TELEMETRY_PER_MIN=20
