CLOUD_BASE_URL=https://eye-in-the-sky-web.vercel.app/
STATION_API_KEY=eis_your_key_from_register
COMMAND_POLL_INTERVAL_MS=180000
#
# Defaults: no GNSS until NMEA is wired in gps.ts; no environmental sensor readings until real drivers exist; no tiny JPEG unless opted in below.
# Wi-Fi + Mozilla MLS fallback when GNSS has no fix is ON by default (no env needed). Set WIFI_POSITIONING=0 to disable.
# Production: set CAPTURE_STILL_CMD for stills.
#
# --- Optional: pipeline test without camera ---
# MOCK_CAMERA=1
#
# Wi-Fi positioning (Mozilla Location Service) when GNSS has no fix — on by default; coarse, not for orchestrator tier.
# Requires Wi-Fi scan (often: sudo cap on `iw`, or WIFI_IW_USE_SUDO=1 + passwordless sudo for `iw`).
# WIFI_POSITIONING=0
# WIFI_SCAN_IFACE=wlan0
# WIFI_GEOLOC_MIN_INTERVAL_MS=600000
# Optional MLS API key (higher quotas): https://ichnaea.readthedocs.io/en/latest/local_dev.html
# MOZILLA_LOCATION_API_KEY=
# If MLS returns no position, coarse lat/lon from public IP (geojs.io). Opt out: WIFI_IP_GEO_FALLBACK=0
# If GNSS + Wi-Fi + IP geo all fail, edge uses GET /api/stations/me/location (MongoDB `stations.location` from last good telemetry or manual set).
# WIFI_IW_USE_SUDO=1
# Custom scan: prints `iw` scan text or lines `aa:bb:cc:dd:ee:ff -72`
# WIFI_SCAN_CMD=
# Reject calibration_sky_probe when fix is Wi-Fi only (telemetry still sends Wi-Fi position): ALLOW_WIFI_FOR_AIM=0
# Tilt trim (deg, positive = aim higher) lives in Mongo calibration.mount_tilt_offset_deg or via:
#   curl -X PATCH "$CLOUD/api/stations/me/mount" -H "Authorization: Bearer $STATION_API_KEY" \
#     -H "Content-Type: application/json" -d '{"mount_tilt_offset_deg":5}'
# True-north boresight offset (deg) is computed on the server during sun calibration and sent on /commands + /mount.
# Initial settle before fixed-mount calibration sequence (ms).
# CALIBRATION_HOME_SETTLE_MS=2500
# Between calibration progress phases before still (default 800 ms).
# CALIBRATION_POSE_SETTLE_MS=800
#
# run_calibration stills default to a conservative 1080p AF line (see capture-jpeg.ts) so full-res CAPTURE_STILL_CMD does not break calibration.
# Override explicitly, or set CALIBRATION_MATCH_CAPTURE_STILL_CMD=1 to use the same command/template as capture_now / ops.
# CALIBRATION_MATCH_CAPTURE_STILL_CMD=1
# Optional: custom calibration-only command (single camera).
# CALIBRATION_CAPTURE_STILL_CMD=rpicam-still -e jpg -n -t 4000 --autofocus-on-capture --width 2312 --height 1736 -o -
# Omni: optional template with {{INDEX}}; if unset, calibration uses the built-in conservative template (not CAPTURE_STILL_CMD_TEMPLATE).
# CALIBRATION_CAPTURE_STILL_CMD_TEMPLATE=rpicam-still -e jpg -n --immediate --camera {{INDEX}} --width 1920 --height 1080 -o -
# Shell timeout for calibration still only (ms). Default 120000; raise only if captures are legitimately slow.
# CALIBRATION_CAPTURE_TIMEOUT_MS=180000
# Real stills: shell command must write JPEG to stdout.
# Install (most Pi OS): sudo apt update && sudo apt install -y libcamera-apps
#
# BLURRY / NO DETAIL: JPEG -q does not fix focus. Typical causes:
#   • --immediate grabs the first frame before autofocus runs — REMOVE it for AF modules (Arducam 64MP, Pi Cam 3).
#   • Add --autofocus-on-capture and -t 4000–8000 (ms) so AF + exposure can settle (-n = no preview window).
#   • Use higher --width/--height (1080p looks soft on a 64MP sensor); try 4624x3472 or full 9152x6944 if RAM + MAX_CAPTURE_BYTES allow.
#   • Motion: mount vibration; shorten exposure with --shutter 8000 (µs) if needed.
#
# JPEG quality: agent appends `-q N` (default 96) unless CMD already has -q/--quality.
# CAPTURE_JPEG_QUALITY=98   # or none to control -q only in CMD
#
# Before S3 upload, still JPEGs are rotated (default 180° for upside-down camera mount). Re-encode via sharp.
# UPLOAD_JPEG_ROTATE_DEG=180
# UPLOAD_JPEG_ROTATE_DEG=0   # disable (upload pixels as captured)
#
# Arducam 64MP AF (sharp still, stdout JPEG) — adjust -t / resolution to your Pi RAM and server upload limit:
# CAPTURE_STILL_CMD=rpicam-still -e jpg -n -t 6000 --autofocus-on-capture --width 4624 --height 3472 -o -
# Pi 4B+/5 + large uploads: try --width 9152 --height 6944 (may need MAX_CAPTURE_BYTES on Vercel)
#
# Fast / fixed-focus modules only (OK to skip AF delay):
# CAPTURE_STILL_CMD=rpicam-still -e jpg -n --immediate --width 1920 --height 1080 -o -
# Or: rpicam-jpeg -n --immediate --width 1920 --height 1080 -o -
# Older libcamera-still (if present): -e jpg, not jpeg
# CAPTURE_STILL_CMD=libcamera-still -e jpg -n --immediate --width 1280 --height 720 -o -
# Very old camera stack: sudo apt install -y libraspberrypi-bin
# CAPTURE_STILL_CMD=raspistill -n -w 1280 -h 720 -o -
# If -o - is unsupported, use: sh -c 'rpicam-still ... -o /tmp/eis.jpg && cat /tmp/eis.jpg'
#
# --- Omni quad / Arducam multi-camera adapter (fixed rig, no pan/tilt) ---
# Register the station with JSON {"omni_quad":true} so cloud crons use capture-only paths.
# OMNI_QUAD=1
# Camera count: unset or OMNI_CAMERA_COUNT=auto → run rpicam-still/libcamera-still --list-cameras (cached 5 min).
# Set OMNI_CAMERA_COUNT=4 to skip detection. MOCK_CAMERA=1 + auto → uses length of OMNI_SLOT_AZIMUTH_DEG list.
# OMNI_CAMERA_COUNT=4
# OMNI_CAMERA_DETECT_CACHE_MS=300000
# OMNI_CAMERA_LIST_TIMEOUT_MS=15000
# Relative azimuth (deg) per slot from slot-0 boresight; need at least as many values as detected/fixed count.
# OMNI_SLOT_AZIMUTH_DEG=0,90,180,270
# Optional shared elevation (deg) on finalize for every slot.
# OMNI_CAPTURE_ELEVATION_DEG=55
# Template must include literal {{INDEX}} for libcamera camera index (0..N-1). Used for capture_now, calibration_sky_probe, and run_calibration (all slots each phase). Real omni paths ignore CAPTURE_STILL_CMD.
# CAPTURE_STILL_CMD_TEMPLATE=rpicam-still -e jpg -n --immediate --camera {{INDEX}} --width 1920 --height 1080 -o -
