CLOUD_BASE_URL=https://eye-in-the-sky-web.vercel.app/
STATION_API_KEY=eis_your_key_from_register
COMMAND_POLL_INTERVAL_MS=180000
GPS_MOCK=1
MOCK_GPS_LAT=37.7749
MOCK_GPS_LON=-122.4194
MOCK_CAMERA=0
# Pan/tilt: mock (default), serial (Pi↔Arduino), or pca9685 (Pi I²C to PCA9685, e.g. 0x40 on bus 1)
# See RASPBERRY_PI.md §5.1 and edge/firmware/pan-tilt-bridge/README.md
# PAN_TILT_DRIVER=mock
# PAN_TILT_DRIVER=serial
# PAN_TILT_SERIAL_PATH=/dev/ttyACM0
# PAN_TILT_SERIAL_PATH=/dev/serial0
# PAN_TILT_SERIAL_BAUD=115200
# PAN_TILT_DRIVER=pca9685
# PAN_TILT_I2C_BUS=1
# PAN_TILT_PCA9685_ADDR=64
# Optional PCA9685 servo travel (defaults match pan-tilt-bridge.ino kOut*). Widen min/max to get more motion per logical degree.
# PAN_TILT_SERVO_PAN_OUT_MIN=0
# PAN_TILT_SERVO_PAN_OUT_MAX=180
# PAN_TILT_SERVO_TILT_OUT_MIN=15
# PAN_TILT_SERVO_TILT_OUT_MAX=145
# npm run test-pan-tilt: ms between poses (long full-envelope run)
# PAN_TILT_TEST_DWELL_MS=2200
# Segments per sweep (more = smoother, longer test)
# PAN_TILT_TEST_SWEEP_STEPS=14
# npm run test-pan-tilt-capture: sparse (default) samples sweep legs; all = every pose (rate limit risk)
# PAN_TILT_CAPTURE_MODE=sparse
# PAN_TILT_CAPTURE_SWEEP_STRIDE=4
# Real stills: shell command must write JPEG to stdout (Pi example below)
# CAPTURE_STILL_CMD=libcamera-still -e jpeg -n --immediate --width 1280 --height 720 -o -
# Optional mock environmental sensors (pluggable drivers; real I2C/SPI later)
MOCK_BME280_TEMP_C=22.5
MOCK_BME280_PRESSURE_HPA=1013.2
MOCK_BME280_HUMIDITY_PCT=48
# MOCK_RAIN_MM=0
# MOCK_WIND_MPS=3.2
# MOCK_LIGHTNING_KM=12
